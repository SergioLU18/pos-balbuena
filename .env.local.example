# Copia este archivo a .env.local y ajusta los valores.

# true  = modo mock (sin backend, todo en memoria/localStorage — útil para desarrollo o demo)
# false = usa Supabase como backend con sincronización en tiempo real
VITE_MOCK=true

# Credenciales del proyecto Supabase de pos-balbuena (Project Settings → API).
# Solo se usan cuando VITE_MOCK=false.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
