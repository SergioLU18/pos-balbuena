# Copia este archivo a .env.local y ajusta los valores.

# true  = modo mock (sin backend, todo en memoria/localStorage — útil para desarrollo o demo)
# false = usa Supabase como backend con sincronización en tiempo real
VITE_MOCK=true

# Credenciales del proyecto Supabase (Project Settings → API). Solo se usan cuando
# VITE_MOCK=false. pos-balbuena comparte el MISMO proyecto que tali: son dos frontends
# del mismo restaurante sobre las mismas tablas (restaurantes/mesas/cuentas/cuenta_items),
# más las tablas propias del POS (meseros/pedidos). Corre en orden en el SQL Editor:
#   supabase/cleanup.sql  →  supabase/schema.sql  →  supabase/seed.sql
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
